SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhoeWNrbWVzbXhqcXF6Y3FqYWptIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MjYxMzc4NSwiZXhwIjoyMDk4MTg5Nzg1fQ.a5pn9kPCAyvWEoMRQb41LUiW6aLOkqIqm3YMDMmGY6w
