{
  "name": "apcrda-tdr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:append": "npx tsx scripts/add-bond-records.ts",
    "db:truncate": "npx tsx scripts/truncate-all-tables.ts",
    "db:studio": "prisma studio",
    "auth:sync": "npx tsx scripts/sync-supabase-auth.ts",
    "cert:backfill": "npx tsx scripts/backfill-certificate-storage.ts",
    "stack:up": "docker compose up postgres cerbos -d",
    "stack:down": "docker compose down",
    "cerbos:start": "powershell -ExecutionPolicy Bypass -File scripts/start-cerbos.ps1",
    "cerbos:start:unix": "bash scripts/start-cerbos.sh",
    "cerbos:docker": "docker compose up cerbos -d",
    "cerbos:compile": "docker run --rm -v \"%cd%/cerbos/policies:/policies\" ghcr.io/cerbos/cerbos:0.53.0 compile /policies",
    "deploy": "bash scripts/deploy.sh",
    "deploy:logs": "docker compose -f docker-compose.yml -f docker-compose.prod.yml -f docker-compose.vm.yml --env-file .env.production logs -f",
    "fabric:bootstrap": "bash fabric/scripts/bootstrap.sh",
    "fabric:start": "docker compose -f fabric/network/docker-compose.yml up -d",
    "fabric:stop": "docker compose -f fabric/network/docker-compose.yml down",
    "fabric:deploy-cc": "bash fabric/scripts/deploy-chaincode.sh",
    "ppt:workflow": "node scripts/generate-workflow-ppt.mjs",
    "ppt:login": "node scripts/generate-login-workflow-ppt.mjs"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@cerbos/core": "^0.31.0",
    "@cerbos/grpc": "^0.27.1",
    "@grpc/grpc-js": "^1.14.4",
    "@hookform/resolvers": "^5.4.0",
    "@hyperledger/fabric-gateway": "^1.11.0",
    "@prisma/client": "^5.22.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "formidable": "^3.5.4",
    "i18next": "^26.3.3",
    "lucide-react": "^1.21.0",
    "next": "^14.2.35",
    "next-i18next": "^16.0.7",
    "next-pwa": "^5.6.0",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/formidable": "^3.5.1",
    "@types/node": "^26.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.49",
    "pptxgenjs": "^4.0.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
