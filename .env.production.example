# ── Supabase (production project) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (set POSTGRES_* in shell or .env for compose; DATABASE_URL built by compose) ──
POSTGRES_USER=apcrda
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-32
POSTGRES_DB=apcrda_tdr

# ── Cerbos PDP (internal Docker network) ──────────────────────────────────────
CERBOS_MOCK_MODE=false
CERBOS_PDP_URL=cerbos:3593
CERBOS_PDP_TLS=false
CERBOS_ADMIN_USER=cerbos-admin
CERBOS_ADMIN_PASSWORD=change-me-strong-password

# ── Hyperledger Fabric ────────────────────────────────────────────────────────
FABRIC_MOCK_MODE=false
FABRIC_PEER_ENDPOINT=fabric-peer:7051
FABRIC_MSP_ID=APCRDA
FABRIC_CERT_PATH=/run/secrets/fabric-cert.pem
FABRIC_KEY_PATH=/run/secrets/fabric-key.pem
FABRIC_TLS_CERT_PATH=/run/secrets/fabric-tls.crt

# ── Security (generate: openssl rand -hex 32) ─────────────────────────────────
HMAC_SECRET=replace-with-64-char-hex
AADHAAR_ENCRYPTION_KEY=replace-with-64-char-hex
COMMISSIONER_CERT_PATH=/run/secrets/commissioner.crt
COMMISSIONER_KEY_PATH=/run/secrets/commissioner.key

# ── SMS (MSG91) ───────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-key
MSG91_SENDER_ID=APCRDA
MSG91_TEMPLATE_ID=your-otp-template-id

# ── APCRDA existing systems ───────────────────────────────────────────────────
APCRDA_LAND_RECORDS_URL=https://landrec.apcrda.ap.gov.in/api
APCRDA_GIS_URL=https://gis.apcrda.ap.gov.in
APCRDA_FARMER_URL=https://farmer.apcrda.ap.gov.in/api
APCRDA_OAUTH_TOKEN_URL=https://auth.apcrda.ap.gov.in/oauth/token
APCRDA_CLIENT_ID=tdr_platform
APCRDA_CLIENT_SECRET=your-client-secret
APCRDA_MOCK_MODE=false

# ── Official SSO ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_OFFICIAL_SSO_ENABLED=true

# ── IPFS (internal Docker network) ────────────────────────────────────────────
IPFS_API_URL=http://ipfs:5001

# ── App version tag for Docker image ──────────────────────────────────────────
APP_VERSION=latest
